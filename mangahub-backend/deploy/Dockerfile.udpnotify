FROM golang:1.25-alpine AS build
WORKDIR /src
COPY go.mod go.sum* ./
RUN go mod download || true
COPY . .
RUN CGO_ENABLED=0 go build -o /out/udp-server ./cmd/udp-server

FROM gcr.io/distroless/static-debian12
COPY --from=build /out/udp-server /udp-server
EXPOSE 9001/udp 9101
ENTRYPOINT ["/udp-server"]
