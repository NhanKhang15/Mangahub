FROM golang:1.25-alpine AS build
WORKDIR /src
COPY go.mod go.sum* ./
RUN go mod download || true
COPY . .
RUN CGO_ENABLED=0 go build -o /out/progress-svc ./cmd/progress-svc

FROM gcr.io/distroless/static-debian12
COPY --from=build /out/progress-svc /progress-svc
EXPOSE 50053
ENTRYPOINT ["/progress-svc"]
